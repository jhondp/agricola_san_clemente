# Copiar este archivo a ".env" (sin ".example") y completar con tus valores.
# ".env" nunca se sube al repositorio (ver .gitignore) — puede tener secretos reales.

# Cadena de conexión a Postgres. En local (Docker, MANUAL.md sección 2):
#   postgresql://postgres:postgres@localhost:5432/piloto_sc
# En Supabase (MANUAL.md sección 3): la cadena "Connection string" del panel,
# con el usuario app_api y la contraseña que le pusiste en 01_schema.sql.
DATABASE_URL=postgresql://app_api:CAMBIAR_ESTA_CLAVE@localhost:5432/piloto_sc

# Ruta al archivo JSON de la cuenta de servicio de Firebase (MANUAL.md sección 4).
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Dominio de correo permitido. Sin "@". Ejemplo: empresa.cl
ALLOWED_DOMAIN=empresa.cl

# De dónde puede llegar el frontend (CORS). En local, la URL donde abrís index.html
# con un servidor simple (MANUAL.md sección 5) — nunca "file://".
FRONTEND_ORIGIN=http://127.0.0.1:5500
